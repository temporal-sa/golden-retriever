# Copy to .env for a local Lakebase-backed rehearsal. The worker, App, migrations, and
# grant CLI automatically load .env from their current working directory without replacing
# variables already supplied by the shell or runtime. Never commit real values.
#
# For per-process files, start a command with RETRIEVAL_ENV_FILE=.env.worker (or another
# explicit path). Set RETRIEVAL_ENV_FILE to an empty string to disable file loading. Values
# such as ${NAME} remain literal: environment-file interpolation is intentionally disabled.

# Temporal connection (local defaults shown; use TLS + an API key for Temporal Cloud).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS=false
TEMPORAL_API_KEY=
TEMPORAL_RETRIEVAL_TASK_QUEUE=retrieval-v2
TEMPORAL_PROVIDER_TASK_QUEUE=retrieval-provider-v2
TEMPORAL_WEB_BASE_URL=http://localhost:8233

# Lakebase/Postgres. Databricks Apps injects PG* plus LAKEBASE_ENDPOINT from
# the `postgres` App resource. For local Postgres, omit LAKEBASE_ENDPOINT and
# set PGPASSWORD through your shell/secret manager instead of this file.
PGHOST=replace-with-endpoint-host
PGPORT=5432
PGDATABASE=databricks_postgres
PGUSER=replace-with-database-identity
PGSSLMODE=require
LAKEBASE_ENDPOINT=projects/replace/branches/replace/endpoints/replace
LAKEBASE_POOL_MIN_SIZE=1
LAKEBASE_POOL_MAX_SIZE=20

# Demo adapters are fail-closed unless explicitly enabled. The scripted bundle below is for a
# local, no-Google rehearsal; production uses the Google Drive bundle shown next.
RETRIEVAL_DEMO_MODE=true
RETRIEVAL_ADAPTER_BUNDLE_FACTORY=retrieval.demo.scripted_provider:create_adapter_bundle
RETRIEVAL_SEARCH_BACKEND=lakebase_hybrid
RETRIEVAL_EMBEDDING_DIMENSION=1024
DATABRICKS_EMBEDDING_ENDPOINT=system.ai.gte-large-en
RETRIEVAL_DEMO_DISPLAY_NAME=Drive retrieval demo
OBJECT_CLEANUP_BATCH_SIZE=250

# Real Google Drive worker. Production staging and connector checkpoints live in Lakebase.
# RETRIEVAL_ADAPTER_BUNDLE_FACTORY=retrieval.google_drive.bundle:create_adapter_bundle
# RETRIEVAL_STAGING_BACKEND=lakebase
# RETRIEVAL_DEMO_PROVIDER=google-drive
# GOOGLE_DRIVE_CREDENTIAL_KEY=workspace-primary
# GOOGLE_DRIVE_USER_KEY=drive-user
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# GOOGLE_DRIVE_HELD_FILE_ID=
# RETRIEVAL_DEMO_HELD_DOCUMENT_KEY=gdrive:<same-held-file-id>
# GOOGLE_DRIVE_CREDENTIALS_FILE=
# GOOGLE_DRIVE_SUBJECT=
# GOOGLE_DRIVE_MAX_FILE_BYTES=10485760  # use 52428800 for the 37 MB demo PDF
# GOOGLE_DRIVE_REQUEST_TIMEOUT=60

# Filesystem staging remains available only for local single-worker adapter tests.
# GOOGLE_DRIVE_STAGING_DIRECTORY=/absolute/local/retrieval-google-drive

# Recommended for a versioned non-local worker deployment.
TEMPORAL_DEPLOYMENT_NAME=retrieval-v2
TEMPORAL_BUILD_ID=replace-with-immutable-build-id
TEMPORAL_USE_WORKER_VERSIONING=true
